# ============================================================
#  Text2SQL Agent — 环境变量配置模板
#  复制为 .env 并填入真实值，不要把 .env 提交到版本控制
# ============================================================

# ── LLM 配置 ────────────────────────────────────────────────
# Tongyi / DashScope API Key（必填）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 可选：用其他 provider 时设置（优先级低于 DASHSCOPE_API_KEY）
# LLM_API_KEY=

LLM_PROVIDER=tongyi          # tongyi | openai | anthropic ...
LLM_MODEL=qwen-plus          # 模型名称，如 qwen-turbo / qwen-max
LLM_TEMPERATURE=0.0          # 0.0 ~ 2.0
# LLM_MAX_TOKENS=             # 不设置则使用模型默认值

# ── 数据库配置 ───────────────────────────────────────────────
DB_URI=sqlite:///Chinook.db  # SQLite 示例；MySQL: mysql+pymysql://user:pass@host/db
DATABASE_MAX_QUERY_RESULTS=5
DATABASE_TIMEOUT_SECONDS=30

# ── LLM 响应缓存（SQLite）───────────────────────────────────
LLM_CACHE_ENABLED=true
LLM_CACHE_BACKEND=sqlite
LLM_CACHE_SQLITE_PATH=.langchain_cache.db

# ── 双塔检索（Milvus）───────────────────────────────────────
RETRIEVAL_ENABLED=true
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
RETRIEVAL_TOP_K=15           # 向量检索返回的最大列数
RETRIEVAL_MAX_TABLES=6       # 最多保留的候选表数
RETRIEVAL_THRESHOLD=0.25     # 向量相似度阈值
RETRIEVAL_FORCE_REBUILD=false  # true = 每次启动重建向量索引

# ── SQL 安全护栏 ─────────────────────────────────────────────
# SECURITY_TABLE_DENYLIST=secret_table,internal_logs   # 逗号分隔
# SECURITY_TABLE_ALLOWLIST=                             # 为空表示允许所有
SECURITY_MAX_ROWS=1000
SECURITY_MAX_QUERY_LENGTH=5000
SECURITY_AUDIT_LOG=true
# SECURITY_AUDIT_LOG_FILE=logs/audit.log               # 不设则只打印日志

# ── 输出路径 ─────────────────────────────────────────────────
REPORT_DIR=report
CHART_DIR=report/charts

# ── 日志配置 ─────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# LOG_FILE_PATH=logs/agent.log
LOG_MAX_FILE_SIZE=10485760   # 10 MB
LOG_BACKUP_COUNT=5
